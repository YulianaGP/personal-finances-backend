// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}


// --------------------
// MODELOS
// --------------------

model Debt {
  id              Int               @id @default(autoincrement())
  debt_name       String            @unique            // HU1: debe ser único
  creditor_name   String
  amount          Decimal           @db.Decimal(20,2)  // total de la deuda
  installments    Int
  monthly_payment Decimal           @db.Decimal(20,2)  // monto mensual esperado (a validar con contribuciones)
  due_date        DateTime
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  // ✅ Soft delete fields:
  is_deleted       Boolean            @default(false)
  deletedAt        DateTime?          

  
  // relación muchos-a-muchos personalizada
  contributors    DebtContributor[]

  @@map("debts")
}

model Contributor {
  id        Int               @id @default(autoincrement())
  name      String            @unique            // Lo marco único para permitir connectOrCreate fácilmente.
                                             // Si prefieres permitir nombres duplicados, puedo quitar @unique.
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt

  debts     DebtContributor[]

  @@map("contributors")
}

model DebtContributor {
  id                  Int       @id @default(autoincrement())
  debtId              Int
  contributorId       Int
  contribution_amount Decimal   @db.Decimal(20,2) // aporte (por ejemplo, aporte mensual)
  is_primary          Boolean   @default(false)   // marca el "primer contribuyente" si lo deseas
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  debt        Debt        @relation(fields: [debtId], references: [id], onDelete: Cascade)
  contributor Contributor @relation(fields: [contributorId], references: [id], onDelete: Cascade)

  @@unique([debtId, contributorId])
  @@index([debtId])
  @@index([contributorId])
  @@map("debt_contributors")
}
